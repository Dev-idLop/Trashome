<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlers.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="40.0" layoutY="50.0" prefHeight="350.0" prefWidth="270.0" spacing="15.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
         <children>
            
            <Label text="Trashome">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="2.0" />
               </VBox.margin>
            </Label>
            <Label text="Inicia sesión para continuar" textFill="#6b6b6b">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
               <font>
                  <Font size="14.0" />
               </font>
            </Label>

            <VBox spacing="5.0">
               <children>
                  <Label text="Usuario:" textFill="#333333">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font></Label>
                  <TextField fx:id="txt_User" prefHeight="35.0" promptText="Ingresa tu usuario" />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Contraseña:" textFill="#333333">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font></Label>
                  <PasswordField fx:id="txt_Password" prefHeight="35.0" promptText="Ingresa tu contraseña" />
               </children>
            </VBox>

            <Button fx:id="btn_Login" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#iniciarSesion" prefHeight="40.0" style="-fx-background-color: #0078D7; -fx-text-fill: white;" text="Ingresar">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>

            <Label fx:id="lbl_mensaje" textFill="#ff3333" />

            <VBox prefHeight="10.0" />

            <VBox alignment="CENTER" spacing="8.0">
               <children>
                  
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label text="¿No tienes cuenta?" textFill="#6b6b6b" />
                        <Hyperlink fx:id="linkRegistro" onAction="#abrirRegistro" text="Regístrate aquí" />
                     </children>
                  </HBox>
                  
                  <Hyperlink fx:id="linkEquipo" onAction="#registroEquipo" text="¿Eres parte de nuestro equipo?" />
                  
               </children>
            </VBox>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
